#include <stdio.h>

int Primo(int n)
{
    int i;
    if (n < 2) return 0;
    for (i = 2; i * i <= n; i++)
    {
        if (n % i == 0) return 0;
    }
    return 1;
}

int main()
{
    int limite, i;
    printf("Ingrese limite (>=1): ");
    scanf("%d", &limite);
    printf("Primos hasta %d:\n", limite);
    for (i = 1; i <= limite; i++)
    {
        if (Primo(i))
        {
            printf("%d\n", i);
        }
    }
    return 0;
}
