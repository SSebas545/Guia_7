#include <stdio.h>

int main()
{
    int n;
    int Impares = 0;
    int sumPares = 0;
    int Pares = 0;
    printf("Ingrese enteros (negativo para terminar):\n");
    scanf("%d", &n);
    while (n >= 0)
    {
        if (n % 2 == 0)
        {
            sumPares += n;
            Pares++;
        }
        else
        {
            Impares += n;
        }
        scanf("%d", &n);
    }
    if (Pares > 0)
    {
        printf("Promedio de pares: %.2f\n", (float)sumPares / Pares);
    }
    else
    {
        printf("No se ingresaron pares\n");
    }
    printf("Suma de impares: %d\n", Impares);
    return 0;
}
