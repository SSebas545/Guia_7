#include <stdio.h>

int main()
{
    int n;
    printf("Ingrese un numero: ");
    scanf("%d", &n);
    if (n > 0)
    {
        printf("Positivo\n");
    }
    else
    {
        if (n < 0)
        {
            printf("Negativo\n");
        }
        else
        {
            printf("Cero\n");
        }
    }
    return 0;
}
