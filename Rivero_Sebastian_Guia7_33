#include <stdio.h>

int main()
{
    float base;
    int exp, i;
    float resultado = 1;
    printf("Ingrese base (real) y exponente (entero no negativo): ");
    scanf("%f %d", &base, &exp);
    if (exp < 0)
    {
        printf("Exponente debe ser entero no negativo\n");
        return 0;
    }
    for (i = 0; i < exp; i++)
    {
        resultado *= base;
    }
    printf("Resultado: %.4f\n", resultado);
    return 0;
}
