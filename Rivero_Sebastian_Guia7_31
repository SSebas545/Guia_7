#include <stdio.h>

int main()
{
    unsigned int n;
    int opcion;
    printf("Ingrese numero decimal: ");
    scanf("%u", &n);
    printf("Menu conversion:\n1. Binario\n2. Octal\n3. Hexadecimal\nElija opcion: ");
    scanf("%d", &opcion);
    if (opcion == 1)
    {
        int bits[32];
        int i = 0;
        unsigned int m = n;
        if (m == 0) { printf("0\n"); return 0; }
        while (m > 0)
        {
            bits[i++] = m % 2;
            m /= 2;
        }
        while (i-- > 0) printf("%d", bits[i]);
        printf("\n");
    }
    else
    {
        if (opcion == 2)
        {
            printf("%o\n", n);
        }
        else
        {
            if (opcion == 3)
            {
                printf("%X\n", n);
            }
            else
            {
                printf("Opcion invalida\n");
            }
        }
    }
    return 0;
}
