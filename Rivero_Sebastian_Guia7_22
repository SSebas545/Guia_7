#include <stdio.h>

int main()
{
    float saldo = 50000;
    int opcion;
    do
    {
        printf("Menu Cajero:\n1. Ver saldo\n2. Retirar\n3. Salir\nElija opcion: ");
        scanf("%d", &opcion);
        if (opcion == 1)
        {
            printf("Saldo actual: $%.2f\n", saldo);
        }
        else
        {
            if (opcion == 2)
            {
                float monto;
                printf("Ingrese monto a retirar: ");
                scanf("%f", &monto);
                if (monto > 0 && monto <= saldo)
                {
                    saldo -= monto;
                    printf("Retiro OK. Saldo: $%.2f\n", saldo);
                }
                else
                {
                    printf("Operacion invalida: monto mayor al saldo o no positivo\n");
                }
            }
        }
    }
    while (opcion != 3);
    printf("Sesion finalizada\n");
    return 0;
}
