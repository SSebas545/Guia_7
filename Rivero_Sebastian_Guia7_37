#include <stdio.h>

int main()
{
    float temp;
    int i;
    float suma = 0;
    int dias_mayor = 0;
    for (i = 1; i <= 7; i++)
    {
        printf("Ingrese temperatura maxima dia %d: ", i);
        scanf("%f", &temp);
        suma += temp;
        if (temp > 25) dias_mayor++;
    }
    printf("Promedio semanal: %.2f\n", suma / 7);
    printf("Dias con temp > 25: %d\n", dias_mayor);
    return 0;
}
